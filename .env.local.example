# Wix CRM Integration
# 1. Go to your Wix Dashboard → Settings → API Keys
# 2. Create a new API key with "Contacts" permissions
# 3. Copy the key here (no "Bearer" prefix needed)
WIX_API_KEY=your_wix_api_key_here

# 4. Your Wix site ID — found in Dashboard → Settings → General Info → Site ID
WIX_SITE_ID=your_wix_site_id_here
